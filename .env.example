# ─────────────────────────────────────────────────────────────────────────────
# book_audiobook_reader configuration
# Copy this file to .env and fill in your values. .env is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ─── TTS provider ────────────────────────────────────────────────────────────
# Which TTS backend to use. Supported:
#   "openai_compatible" — OpenAI, OpenRouter, or any OpenAI-compatible /audio/speech endpoint
#   "elevenlabs"        — ElevenLabs' native /v1/text-to-speech API (George, Rachel, etc.)
#   "mlx_local"         — Local MLX inference on Apple Silicon (free, requires M-series Mac)
TTS_PROVIDER=openai_compatible

# ─── API key & endpoint ──────────────────────────────────────────────────────
# For openai_compatible: an OpenAI / OpenRouter / etc. key
# For elevenlabs:        your ElevenLabs key (https://elevenlabs.io → Profile → API Key)
# For mlx_local:         ignored (no API key needed; runs locally)
TTS_API_KEY=PASTE_...n
# Ignored when TTS_PROVIDER=elevenlabs.
# To use OpenAI directly: https://api.openai.com/v1/audio/speech
# To use OpenRouter:     https://openrouter.ai/api/v1/audio/speech
TTS_API_URL=https://openrouter.ai/api/v1/audio/speech

# ─── MLX local (Apple Silicon only) ──────────────────────────────────────────
# Only used when TTS_PROVIDER=mlx_local. Path to the Python interpreter
# inside your mlx-audio venv (created with `python3 -m venv ~/.venvs/mlx-audio`).
# Performance depends on which Apple Silicon chip you have — see README.
#MLX_PYTHON=/Users/YOU/.venvs/mlx-audio/bin/python
#MLX_MODEL=mlx-community/orpheus-tts-0.1-finetune-bf16
#MLX_VOICE=tara

# ─── Model + voice (openai_compatible) ───────────────────────────────────────
# TTS model identifier. With OpenRouter, prefix with the provider name.
# Confirmed working on OpenRouter as of June 2026 (use the API to list current TTS models:
#   curl "https://openrouter.ai/api/v1/models?output_modalities=speech"):
#   hexgrad/kokoro-82m                    — CHEAPEST; $0/M output, 54 voices, 8 languages
#   openai/gpt-4o-mini-tts-2025-12-15     — DEFAULT; best cost/quality among OpenAI voices
#   openai/tts-1                          — classic ($15/M chars)
#   openai/tts-1-hd                       — highest fidelity ($30/M chars)
#   canopylabs/orpheus-3b-0.1-ft          — expressive English, $0 output
#   mistralai/voxtral-mini-tts-2603       — voice cloning, $0 output
#   x-ai/grok-voice-tts-1.0               — inline speech tags, $0 output
#   microsoft/mai-voice-2                 — Azure SSML, $0 output
#   google/gemini-3.1-flash-tts-preview   — excellent text normalization, 30+ voices
#                                         (Kore/Orus/Aoede/Charon/Fenrir/Puck), ~$1/M output
#                                         Strongly recommended over Kokoro for long-form narration.
# Ignored when TTS_PROVIDER=elevenlabs (uses ELEVENLABS_MODEL_ID below).
TTS_MODEL=openai/gpt-4o-mini-tts-2025-12-15

# Voice — must be one supported by the chosen model.
# gpt-4o-mini-tts voices: alloy, ash, ballad, coral, echo, fable, marin, nova,
#                         onyx, sage, shimmer, verse
#   "shimmer"  — warm, calm, female — good for audiobooks
#   "onyx"     — deep, male, authoritative
#   "ballad"   — expressive, narrative
# Kokoro 82M voices (54 total). 2-letter prefix = language+gender:
#   af_* = American Female, am_* = American Male, bf_* = British Female, bm_* = British Male
#   af_bella, af_sarah, af_nicole, af_sky, af_allison, af_aoede, af_jessica,
#   af_kore, af_nova, af_river,
#   am_adam, am_michael, am_echo, am_eric, am_fenrir, am_liam, am_onyx, am_puck,
#   bf_emma, bf_isabella, bf_alice, bf_lily,
#   bm_george, bm_lewis, bm_daniel, bm_fable
# Default "shimmer" is a gpt-4o-mini-tts voice. Switch to "bf_emma" if you set
# TTS_MODEL=hexgrad/kokoro-82m above.
# Ignored when TTS_PROVIDER=elevenlabs (uses ELEVENLABS_VOICE_ID below).
TTS_VOICE=shimmer

# ─── ElevenLabs-specific ─────────────────────────────────────────────────────
# All of these are ONLY used when TTS_PROVIDER=elevenlabs.

# Voice ID. Find yours at https://elevenlabs.io/voice-library or via the API.
# Popular picks for audiobooks:
#   JBFqnCBsd6RMkjVDRZzb   George  (male,   British, calm)        — DEFAULT
#   21m00Tcm4TlvDq8ikWAM   Rachel  (female, American, calm)
#   AZnzlk1XvdvUeBnXmlld   Domi    (female, American, energetic)
#   ErXwobaYiN019PkySvjV   Antoni  (male,   American, warm)
#   TxGEqnHWrfWFTfGW9XjX   Josh    (male,   American, deep)
#   VR6AewLTigWG4xSOukaG   Arnold  (male,   American, deep)
#   pNInz6obpgDQGcFmaJgB   Adam    (male,   American, narrative)
#   EXAVITQu4vr4xnSDxMaL   Bella   (female, American, calm)
#   MF3mGyEYCl7XYWbV9V6O   Elli    (female, American, young)
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Model: eleven_multilingual_v2 (best quality, 29 languages) — DEFAULT
#         eleven_turbo_v2_5     (faster, lower latency, slightly less expressive)
#         eleven_turbo_v2       (legacy fast)
#         eleven_monolingual_v1 (English-only legacy)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Voice settings (0.0 – 1.0)
ELEVENLABS_STABILITY=0.5        # higher = more monotone, lower = more expressive
ELEVENLABS_SIMILARITY=0.75     # higher = closer to original voice
ELEVENLABS_STYLE=0.0            # higher = more stylised; 0 = natural

# ─── Output tuning ───────────────────────────────────────────────────────────

# Playback speed multiplier. 1.0 = normal, 1.2 = 20% faster (default),
# 1.5 = 50% faster. 0.8 = slower for very dense technical books.
# Most providers cap this at 0.25–4.0. Ignored by ElevenLabs (no speed param;
# use ffmpeg atempo to adjust the final MP3 if needed).
TTS_SPEED=1.2

# Output audio format: mp3 (default), opus, aac, flac, wav, pcm
TTS_FORMAT=mp3

# Steerable prosody instructions. Sent only when model is gpt-4o-mini-tts-* (or
# other steerable models). Ignored by Kokoro, Orpheus, MAI-Voice-2, etc.
# Set to "" to disable. Edit freely to taste the voice.
TTS_INSTRUCTIONS=Speak in a calm, warm British female voice. Pace the narration naturally, with gentle pauses at paragraph breaks. Suitable for an audiobook recording.

# Max characters per TTS request. Stay under the provider's input cap
# (gpt-4o-mini-tts: 2000 input tokens ≈ 8000 chars; Kokoro: 4K context ≈ 4000 chars;
# ElevenLabs free tier: ~5000). ElevenLabs paid tiers allow much larger requests
# but 5000 is the safe default.
TTS_CHUNK_CHARS=4500

# Retry behaviour for transient HTTP 429/5xx and network errors
TTS_MAX_RETRIES=4
TTS_RETRY_BACKOFF=2.0

# Per-request timeout in seconds
TTS_REQUEST_TIMEOUT=180

# Input/output folders (relative to repo root)
INPUT_DIR=epubs
OUTPUT_DIR=audiobooks

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
