# ─────────────────────────────────────────────────────────────────────────────
# book_audiobook_reader configuration
# Copy this file to .env and fill in your values. .env is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Your OpenRouter (or other OpenAI-compatible) API key
TTS_API_KEY=PASTE_YOUR_KEY_HERE

# Endpoint for the OpenAI-compatible /audio/speech route
# Default: OpenRouter. To use OpenAI directly, set to:
#   https://api.openai.com/v1/audio/speech
# Any provider that exposes OpenAI's audio/speech schema works.
TTS_API_URL=https://openrouter.ai/api/v1/audio/speech

# TTS model identifier. With OpenRouter, prefix with the provider name.
# Other cheap options:
#   openai/gpt-4o-mini-tts   (default — recommended for cost/quality)
#   openai/tts-1             ($15/M chars, classic)
#   openai/tts-1-hd          ($30/M chars, highest fidelity)
TTS_MODEL=openai/gpt-4o-mini-tts

# Voice — must be one supported by the chosen model.
# gpt-4o-mini-tts voices: alloy, ash, ballad, cedar, coral, echo, fable,
#                         marin, nova, onyx, sage, shimmer, verse
#
# Default "shimmer" is warm, calm, female — good for audiobooks.
# Other calm female-friendly options: nova, coral, sage, ballad.
TTS_VOICE=shimmer

# Playback speed multiplier. 1.0 = normal, 1.2 = 20% faster (default),
# 1.5 = 50% faster. 0.8 = slower for very dense technical books.
# Most providers cap this at 0.25–4.0.
TTS_SPEED=1.2

# Output audio format: mp3 (default), opus, aac, flac, wav, pcm
TTS_FORMAT=mp3

# Steerable prosody instructions. Sent only when model is gpt-4o-mini-tts.
# Set to "" to disable. Edit freely to taste the voice.
TTS_INSTRUCTIONS=Speak in a calm, warm British female voice. Pace the narration naturally, with gentle pauses at paragraph breaks. Suitable for an audiobook recording.

# Max characters per TTS request. Stay under the provider's input cap
# (gpt-4o-mini-tts: 2000 input tokens ≈ 8000 chars, but we play safe at 4000).
TTS_CHUNK_CHARS=4000

# Retry behaviour for transient HTTP 429/5xx and network errors
TTS_MAX_RETRIES=4
TTS_RETRY_BACKOFF=2.0

# Per-request timeout in seconds
TTS_REQUEST_TIMEOUT=180

# Input/output folders (relative to repo root)
INPUT_DIR=epubs
OUTPUT_DIR=audiobooks

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
