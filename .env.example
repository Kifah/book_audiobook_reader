# ─────────────────────────────────────────────────────────────────────────────
# book_audiobook_reader configuration
# Copy this file to .env and fill in your values. .env is gitignored.
#
# NORMAL USE: set the 5 ESSENTIALS below and you're done. Every other setting
# has a safe built-in default in convert_books.py — only touch the "Advanced
# overrides" section if you have a specific reason. Fewer knobs = fewer ways to
# misconfigure (e.g. an oversized TTS_CHUNK_CHARS that silently truncates audio).
# ─────────────────────────────────────────────────────────────────────────────

# ═══ ESSENTIALS (the only settings you normally need) ════════════════════════

# Your API key. For OpenRouter: https://openrouter.ai/keys
# For OpenAI direct: https://platform.openai.com/api-keys
TTS_API_KEY=PASTE_YOUR_KEY_HERE

# OpenAI-compatible /audio/speech endpoint.
#   OpenRouter: https://openrouter.ai/api/v1/audio/speech
#   OpenAI:     https://api.openai.com/v1/audio/speech
TTS_API_URL=https://openrouter.ai/api/v1/audio/speech

# TTS model. With OpenRouter, prefix with the provider name. Examples:
#   google/gemini-3.1-flash-tts-preview  — recommended; great normalization, ~$1/M
#   openai/gpt-4o-mini-tts-2025-12-15    — best cost/quality among OpenAI voices
#   hexgrad/kokoro-82m                   — cheapest ($0 output), 54 voices
# List current TTS models: curl "https://openrouter.ai/api/v1/models?output_modalities=speech"
TTS_MODEL=google/gemini-3.1-flash-tts-preview

# Voice ("the reader") — must be supported by the chosen model.
#   Gemini:          Kore, Orus, Aoede, Charon, Fenrir, Puck
#   gpt-4o-mini-tts: shimmer, onyx, ballad, coral, sage, nova, ...
#   Kokoro:          bf_emma, bm_george, af_bella, am_adam, ...
TTS_VOICE=Charon

# Playback speed. 1.0 = normal, 1.2 = 20% faster (default), 1.5 = fast.
TTS_SPEED=1.2


# ═══ ADVANCED OVERRIDES (optional — built-in defaults shown) ═════════════════
# Uncomment a line ONLY to override its default. Leaving them commented uses the
# value baked into convert_books.py.

# --- Provider selection -------------------------------------------------------
# openai_compatible (default) · elevenlabs · piper_local · mlx_local (Apple Silicon)
# TTS_PROVIDER=openai_compatible

# --- Chunking & resilience (engineering constants — change with care) ---------
# TTS_CHUNK_CHARS: max chars per TTS request. 2500 is the safe value; larger
# values make some providers (e.g. Gemini) silently truncate audio mid-chunk.
# TTS_CHUNK_CHARS=2500
# TTS_MAX_RETRIES=4
# TTS_RETRY_BACKOFF=2.0
# TTS_REQUEST_TIMEOUT=180

# Silent-truncation guard: retries chunks whose audio is implausibly short for
# the input text. On by default; disable only if it false-positives for you.
# TTS_VERIFY_AUDIO_LEN=1
# TTS_MIN_AUDIO_RATIO=0.5
# TTS_VERIFY_MIN_CHARS=200

# Parallel TTS requests per chapter (1 = sequential). Lower if you hit 429s.
# TTS_PARALLEL=4

# --- Output format ------------------------------------------------------------
# TTS_FORMAT=mp3
# TTS_BITRATE=64k
# TTS_CHANNELS=1
# CHAPTER_CONCAT_MODE=auto

# Steerable prosody — sent only to gpt-4o-mini-tts-* models; ignored elsewhere.
# TTS_INSTRUCTIONS=Speak in a calm, warm British female voice. Pace the narration naturally, with gentle pauses at paragraph breaks. Suitable for an audiobook recording.

# --- Book processing ----------------------------------------------------------
# INPUT_DIR=epubs
# OUTPUT_DIR=audiobooks
# LOG_LEVEL=INFO
# SKIP_FRONT_MATTER and CLEAN_FOR_TTS are also CLI flags
# (--skip-front-matter / --no-skip-front-matter, --clean / --no-clean).

# --- ElevenLabs (only when TTS_PROVIDER=elevenlabs) ---------------------------
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb   # George (male, British, calm)
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_STABILITY=0.5
# ELEVENLABS_SIMILARITY=0.75
# ELEVENLABS_STYLE=0.0

# --- MLX local (only when TTS_PROVIDER=mlx_local; Apple Silicon) ---------------
# Run ./scripts/setup_mlx.sh first. NOTE: mlx-audio 0.4.4 has a model bug.
# MLX_PYTHON=/Users/YOU/.venvs/mlx-audio/bin/python
# MLX_MODEL=mlx-community/Kokoro-82M-bf16
# MLX_VOICE=af_bella

# --- Piper local (only when TTS_PROVIDER=piper_local) -------------------------
# Free, fully offline, CPU-only TTS. Works on any platform (Mac/Linux/Windows).
# Setup:
#   pip install piper-tts
#   mkdir -p piper_voices && cd piper_voices
#   curl -LO https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/ryan/high/en_US-ryan-high.onnx
#   curl -LO https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/ryan/high/en_US-ryan-high.onnx.json
# Voice catalog (browse + listen): https://rhasspy.github.io/piper-samples/
# PIPER_VOICE_PATH=piper_voices/en_US-ryan-high.onnx
# PIPER_BIN=piper   # optional: override the piper executable lookup
